# Required — MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# Required — secret used to sign JWT tokens (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# Optional — how many days before an election document is auto-deleted (default: 30)
ELECTION_EXPIRY_DAYS=30

# Set automatically by Railway — do not set manually
# PORT=3001
